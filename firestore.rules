rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers scoped to this database
    function authUser() {
      return request.auth != null ? request.auth.uid : null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(authUser()));
    }

    function userData() {
      return userDoc().data;
    }

    function userRole() {
      let data = userData();
      return (data != null && data.role != null ? data.role : "").lower();
    }

    function isBootstrapMaster() {
      return request.auth != null &&
        (request.auth.uid == "rpdLNx3X4CZhFvB6O9bvXbFA72y1" || request.auth.uid == "ljfZse4jR6a7N9ryivGtlGne9Rh2");
    }

    function isMaster() {
      return isBootstrapMaster() || userRole() == "master";
    }

    function isEditor() {
      return userRole() == "editor";
    }

    function hasPermission(key) {
      let data = userData();
      let perms = (data != null && data.permissions != null) ? data.permissions : [];
      return isMaster() || (isEditor() && perms.hasAny([key]));
    }

    // Users
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isMaster() || request.auth.uid == userId);
      // O próprio dono pode editar seu perfil (nome, foto); master pode editar/deletar qualquer um
      allow update: if isMaster() || request.auth.uid == userId;
      allow delete: if isMaster();
    }

    // Estoque
    match /stock_items/{docId} {
      allow read: if request.auth != null;
      allow write: if hasPermission("estoque");
    }

    // Eventos (leitura pública para exibir próximo evento na tela de login)
    match /events/{docId} {
      allow read: if true;
      allow write: if hasPermission("eventos");
    }

    // Caixa
    match /cash_transactions/{docId} {
      allow read: if request.auth != null;
      allow write: if hasPermission("caixa");
    }

    // Mensalidades
    match /memberships/{docId} {
      allow read: if request.auth != null;
      allow write: if hasPermission("mensalidades");
    }

    // Fichas focais (dashboard)
    match /focus_notes/{docId} {
      allow read: if request.auth != null;
      allow write: if hasPermission("dashboard");
    }

    // Cantigas
    match /cantigas/{docId} {
      allow read: if request.auth != null;
      allow write: if hasPermission("cantigas");
    }

    // Ações / pendências
    match /action_items/{docId} {
      allow read: if request.auth != null;
      allow write: if hasPermission("dashboard");
    }

    // Logs
    match /logs/{logId} {
      allow read: if request.auth != null;
      // qualquer usuário autenticado pode registrar logs (usados por todas as abas)
      allow write: if request.auth != null;
    }

    // Doações
    match /doacoes/{docId} {
      allow read: if request.auth != null;
      allow write: if isMaster() || isEditor();
    }

    // Chat (grupos)
    match /chat_groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isMaster();

      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if isMaster() || resource.data.authorUid == request.auth.uid;
      }
    }

    // Chat legado (manter compatibilidade)
    match /chat_messages/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Presença de usuários
    match /user_presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Galeria
    match /galeria/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if isMaster() || isEditor();
      // Qualquer membro pode curtir (update no array likes)
      allow update: if request.auth != null;

      // Comentários da galeria — qualquer membro pode comentar
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null &&
          (isMaster() || resource.data.authorUid == request.auth.uid);
      }
    }

    // Fundamentos
    match /fundamentos/{docId} {
      allow read: if request.auth != null;
      allow write: if isMaster() || isEditor();
    }

    // Settings (modo restrito, metas, baselines, etc.)
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isMaster() || (hasPermission("caixa") && docId in ["caixa_goal", "caixa_entradas_baseline"]);
    }

    // IPs bloqueados (leitura pública para checagem no login, escrita autenticada)
    match /blocked_ips/{ipId} {
      allow read: if true;
      allow write: if true;
    }

    // Presença de usuários (cada um escreve o próprio, todos leem)
    match /user_presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
